# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB Configuration
# Lokal:  mongodb://localhost:27017/
# Cloud:  mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
MONGO_URI=mongodb://localhost:27017/
DB_NAME=pdf_intelligence_db

# Qdrant Vector DB Configuration
# Lokal (Docker):  QDRANT_HOST=localhost, QDRANT_PORT=6333, kein API Key
# Cloud:           QDRANT_HOST=abc-123.us-east4-0.gcp.cloud.qdrant.io
#                  QDRANT_API_KEY=your-qdrant-api-key
#                  QDRANT_HTTPS=true
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_HTTPS=false

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
# WICHTIG: In Produktion einen langen zufälligen String verwenden!
# Generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev_secret_key_change_in_production

# File Upload Configuration
UPLOAD_FOLDER=uploads/
MAX_CONTENT_LENGTH=52428800
